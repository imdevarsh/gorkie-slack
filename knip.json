{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": [".agents/skills/**", ".claude/skills/**"],
  "ignoreDependencies": [
    "@biomejs/biome",
    "@cspell/dict-bash",
    "@cspell/dict-npm",
    "@cspell/dict-redis",
    "@repo/cspell-config",
    "cspell"
  ],
  "tags": ["-lintignore"],
  "workspaces": {
    ".": {
      "entry": ["taze.config.ts", "turbo/generators/config.ts"]
    },
    "apps/docs": {
      "entry": [
        "press.config.tsx",
        "source.config.ts",
        "src/app.css",
        "src/mdx.tsx",
        "waku.config.ts"
      ],
      "project": ["**/*.{ts,tsx}"]
    },
    "apps/bot": {
      "project": ["src/**/*.ts"]
    },
    "packages/ai": {
      "project": ["src/**/*.ts"]
    },
    "packages/db": {
      "project": ["src/**/*.ts"]
    },
    "packages/logging": {
      "project": ["src/**/*.ts"]
    },
    "packages/sandbox": {
      "project": ["src/**/*.ts"]
    },
    "packages/utils": {
      "project": ["src/**/*.ts"]
    },
    "tooling/cspell": {
      "project": ["**/*.ts"]
    }
  }
}
