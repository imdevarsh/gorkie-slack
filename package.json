{
  "name": "gorkie-slack",
  "version": "1.0.0",
  "license": "MIT",
  "description": "A helpful AI Slack Bot built with AI SDK.",
  "private": true,
  "scripts": {
    "dev": "bun run --watch server/index.ts",
    "start": "bun run server/index.ts",
    "sandbox:build": "bun run server/scripts/build-template.ts",
    "sandbox:test": "bun run server/scripts/sandbox-test.ts",
    "proxy:test": "bun run server/scripts/proxy-test.ts",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "dbgenerate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "check": "ultracite check .",
    "check:spelling": "cspell -c .cspell.jsonc --no-progress --no-summary --no-must-find-files --unique --cache",
    "check:unsafe": "ultracite fix --unsafe true .",
    "check:write": "ultracite fix .",
    "typecheck": "tsc --noEmit",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.78",
    "@ai-sdk/openai": "^3.0.64",
    "@e2b/code-interpreter": "^2.4.2",
    "@earendil-works/pi-coding-agent": "^0.75.4",
    "@hono/zod-validator": "^0.8.0",
    "@langfuse/otel": "^5.3.0",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "@opentelemetry/sdk-node": "^0.218.0",
    "typebox": "1.1.38",
    "@slack/bolt": "^4.7.2",
    "@t3-oss/env-core": "^0.13.11",
    "ai": "^6.0.188",
    "ai-retry": "^1.7.4",
    "cron-parser": "^5.5.0",
    "date-fns": "^4.2.1",
    "drizzle-orm": "^0.45.2",
    "e2b": "^2.21.0",
    "exa-js": "^2.13.0",
    "hono": "^4.12.21",
    "p-queue": "^9.3.0",
    "pako": "^2.1.0",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "sanitize-filename": "^1.6.4",
    "slack-block-builder": "^2.8.0",
    "strip-ansi": "^7.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@commitlint/types": "^21.0.1",
    "@cspell/dict-bash": "^4.2.2",
    "@types/bun": "^1.3.14",
    "@types/pako": "^2.0.4",
    "cspell": "^10.0.0",
    "drizzle-kit": "^0.31.10",
    "lefthook": "^2.1.8",
    "typescript": "^6.0.3",
    "ultracite": "7.7.0"
  }
}
