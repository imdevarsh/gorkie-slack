{
  "name": "server",
  "type": "module",
  "scripts": {
    "clean": "git clean -xdf .turbo .output node_modules",
    "build": "nitro build",
    "dev": "nitro dev --port 8000",
    "prepare": "nitro prepare",
    "preview": "NODE_ENV=production srvx --prod .output/",
    "start": "NODE_ENV=production srvx --prod .output/",
    "typecheck": "bun run prepare && tsc --noEmit --skipLibCheck"
