    "@repo/utils": "workspace:*",
    "@repo/validators": "workspace:*",
    "@t3-oss/env-core": "catalog:",
    "dotenv": "catalog:",
    "escape-html": "^1.0.3",
    "nitro": "catalog:",
    "srvx": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@repo/tsconfig": "workspace:*",
    "@types/bun": "catalog:",
    "@types/escape-html": "^1.0.4",
    "@types/node": "catalog:",
    "typescript": "catalog:"
  }
}
