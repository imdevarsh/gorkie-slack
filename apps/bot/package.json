{
  "name": "bot",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "clean": "git clean -xdf .turbo dist node_modules",
    "build": "tsdown",
    "dev": "bun run --hot src/index.ts",
    "start": "NODE_ENV=production bun run dist/index.mjs",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@ai-sdk/harness": "catalog:",
    "@ai-sdk/harness-pi": "catalog:",
    "@repo/db": "workspace:*",
    "@repo/logging": "workspace:*",
    "@repo/utils": "workspace:*",
    "@repo/validators": "workspace:*",
    "@t3-oss/env-core": "catalog:",
    "ai": "catalog:",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@repo/tsconfig": "workspace:*",
    "@types/bun": "catalog:",
    "tsdown": "^0.22.0",
    "typescript": "catalog:"
  }
}
