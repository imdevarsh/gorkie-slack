{
  "name": "@repo/db",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./client": {
      "default": "./src/client.ts"
    },
    "./keys": {
      "default": "./src/keys.ts"
    },
    "./queries": {
      "default": "./src/queries/index.ts"
    },
    "./queries/*": {
      "default": "./src/queries/*.ts"
    },
    "./schema": {
      "default": "./src/schema/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@t3-oss/env-core": "catalog:",
    "dotenv": "catalog:",
    "drizzle-orm": "^0.45.1",
    "pg": "^8.21.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@repo/tsconfig": "workspace:*",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.31.8",
    "typescript": "catalog:"
  }
}
